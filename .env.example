# Copiar a .env y completar
# API key de Anthropic para el diagnóstico con IA (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Clave para cifrar credenciales de equipos en la base de datos local (cualquier texto largo aleatorio)
SECRET_KEY=cambia-esto-por-un-texto-aleatorio-largo

# Puerto del servidor web
PORT=3000
